    {
      "name": "Authentication",
      "item": [
        {
          "name": "Generate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let response = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"token\", response.token);\r",
                  "\r",
                  "pm.test(\"Token exists\", function () {\r",
                  "    pm.expect(response.token).to.not.be.empty;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v2/users/generate-token-for-interview-task",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "users",
                "generate-token-for-interview-task"
              ]
            },
            "description": "Purpose:  \nGenerate a valid access token to authenticate subsequent API requests.\n\nExpected Result:  \nA valid token is returned and stored in the environment for reuse."
          },
          "response": []
        }
      ]
